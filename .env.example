# 성형외과 FAQ RAG 데모 시스템 환경변수
# Notion 연결은 사용하지 않습니다.

# OpenAI API Key 하나로 임베딩 + ChatGPT 답변 생성을 모두 처리합니다.
OPENAI_API_KEY=sk-your-openai-api-key

# 선택: 기본값은 gpt-4o-mini
OPENAI_CHAT_MODEL=gpt-4o-mini

# Vector DB backend
# - chroma: 로컬 ChromaDB, 기본값
# - supabase: 공개 웹/클라우드용 Supabase Postgres + pgvector
VECTOR_DB_BACKEND=chroma

# VECTOR_DB_BACKEND=supabase일 때만 필요
# Supabase Dashboard > Project Settings > Database > Connection string > URI
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
SUPABASE_VECTOR_TABLE=faq_vectors
